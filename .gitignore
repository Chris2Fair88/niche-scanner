# Ingested API data + local SQLite db -- not source, and may contain
# API-derived content not meant for version control. Directory structure
# is preserved via data/.gitkeep.
data/*
!data/.gitkeep

# Generated voiceover audio (mp3) + alignment JSON from produce_voiceover.py --
# binary media generated from an already-reviewed script, not source, and
# not meant for version control (same treatment as data/ above). Directory
# structure is preserved via audio/.gitkeep.
audio/*
!audio/.gitkeep

# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# Virtual environments
.venv/
venv/
env/

# OS cruft
.DS_Store
Thumbs.db

# Local secrets, should never be committed (config.yaml only stores env var
# *names*, never actual keys, but this guards against an accidental .env)
.env
.env.*
